<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProKesMas - Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px); }
        .bg-medical { background: #f1f5f9; background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 24px 24px; }
        .card-shadow { box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05); }
        .custom-scrollbar::-webkit-scrollbar { width: 5px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #64748b; border-radius: 10px; }
    </style>
</head>
<body class="bg-medical min-h-screen text-slate-900">

    <nav class="bg-slate-900 sticky top-0 z-50 p-4 shadow-2xl">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="bg-emerald-500 p-2 rounded-xl text-slate-900 shadow-lg shadow-emerald-500/20">
                    <i class="fas fa-hospital-user text-xl"></i>
                </div>
                <h1 class="text-2xl font-extrabold text-white tracking-tighter">ProKesMas</h1>
            </div>
            <div class="flex items-center space-x-4">
                <div class="text-right hidden md:block">
                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em]">Role Aktif</p>
                    <p class="text-sm font-black text-emerald-400 uppercase"><%= user.role %></p>
                </div>
                <a href="/logout" class="bg-red-500/10 text-red-500 p-3 rounded-xl hover:bg-red-500 hover:text-white transition-all duration-300 border border-red-500/20">
                    <i class="fas fa-power-off"></i>
                </a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-6">
        
        <% if (user.role === 'pasien') { %>
        <div class="space-y-8">
            <div class="bg-white p-8 rounded-[2rem] card-shadow border border-white flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="flex items-center space-x-6">
                    <div class="w-24 h-24 bg-indigo-600 rounded-[2rem] flex items-center justify-center text-white text-4xl font-extrabold shadow-xl shadow-indigo-200 rotate-3">
                        <%= myProfile ? myProfile.nama_lengkap.charAt(0) : 'U' %>
                    </div>
                    <div>
                        <h2 class="text-3xl font-extrabold text-slate-800"><%= myProfile ? myProfile.nama_lengkap : 'User' %></h2>
                        <p class="text-slate-500 font-semibold italic"><i class="fas fa-map-marker-alt mr-2 text-indigo-500"></i><%= myProfile ? myProfile.alamat : '-' %></p>
                        <span class="inline-block mt-3 bg-indigo-50 px-4 py-1.5 rounded-full text-[10px] font-bold text-indigo-700 uppercase tracking-wider border border-indigo-100">ID Pasien: #00<%= user.id %></span>
                    </div>
                </div>
                <div class="bg-slate-900 p-6 rounded-3xl text-center min-w-[160px] shadow-2xl">
                    <p class="text-5xl font-black text-emerald-400"><%= myProfile ? getAge(myProfile.tgl_lahir) : 0 %></p>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-2 italic">Usia Anda</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div class="bg-white p-8 rounded-[2.5rem] card-shadow border border-slate-100">
                    <h3 class="text-xl font-extrabold text-slate-800 mb-6 flex items-center">
                        <i class="fas fa-calendar-check mr-3 text-indigo-600 text-2xl"></i> Registrasi Antrean
                    </h3>
                    <form action="/booking" method="POST" class="space-y-4 mb-8">
                        <input type="hidden" name="nama_pasien" value="<%= myProfile ? myProfile.nama_lengkap : '' %>">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-1">
                                <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Pilih Layanan Poli</label>
                                <select name="layanan" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl font-bold focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all">
                                    <option>Poli Umum</option><option>Poli Gigi</option><option>Poli KIA/Imunisasi</option>
                                </select>
                            </div>
                            <div class="space-y-1">
                                <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Rencana Kunjungan</label>
                                <input type="date" id="inputTgl" name="tanggal" required class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl font-bold focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all">
                            </div>
                        </div>
                        <button type="submit" class="w-full bg-indigo-600 text-white font-extrabold py-5 rounded-2xl hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-200 uppercase tracking-widest text-sm">Ambil Nomor Antrean</button>
                    </form>

                    <div class="space-y-4 max-h-[400px] overflow-y-auto pr-3 custom-scrollbar">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Tiket Antrean Anda</p>
                        <% myBookings.forEach((ticket, index) => { 
                            const isExpired = new Date(ticket.tanggal) < new Date().setHours(0,0,0,0) && ticket.status !== 'selesai';
                        %>
                        <div class="p-6 rounded-3xl border-2 <%= isExpired ? 'bg-slate-50 border-slate-200' : 'bg-white border-indigo-50 shadow-sm' %> flex flex-col gap-4">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-lg font-black <%= isExpired ? 'text-slate-400 line-through' : 'text-slate-800' %>"><%= ticket.kode_booking %></p>
                                    <p class="text-[10px] text-indigo-500 font-bold uppercase"><%= ticket.layanan %></p>
                                </div>
                                <span class="text-[9px] font-black px-3 py-1.5 rounded-full uppercase tracking-tighter <%= isExpired ? 'bg-slate-200 text-slate-500' : 'bg-emerald-500 text-white shadow-lg shadow-emerald-200' %>"><%= isExpired ? 'Expired' : ticket.status %></span>
                            </div>
                            <% if (!isExpired && ticket.status !== 'selesai') { %>
                                <div class="bg-slate-50 p-4 rounded-2xl flex justify-center border border-slate-100 shadow-inner">
                                    <svg id="barcode-<%= index %>"></svg>
                                </div>
                                <script>JsBarcode("#barcode-<%= index %>", "<%= ticket.kode_booking %>", { height: 40, width: 2, displayValue: false, margin: 0 });</script>
                            <% } %>
                        </div>
                        <% }) %>
                    </div>
                </div>

                <div class="bg-white p-8 rounded-[2.5rem] card-shadow border border-slate-100 overflow-hidden flex flex-col">
                    <h3 class="text-xl font-extrabold text-slate-800 mb-6 flex items-center">
                        <i class="fas fa-notes-medical mr-3 text-red-500 text-2xl"></i> Catatan Medis Digital
                    </h3>
                    <div class="space-y-4 overflow-y-auto pr-3 custom-scrollbar flex-1">
                        <% medicalHistory.forEach(medis => { %>
                            <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 border-l-4 border-l-red-500">
                                <div class="flex justify-between mb-3">
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest"><%= new Date(medis.tanggal_periksa).toLocaleDateString() %></p>
                                    <i class="fas fa-heartbeat text-red-200"></i>
                                </div>
                                <p class="font-extrabold text-lg text-slate-800 leading-tight mb-2">"<%= medis.diagnosis %>"</p>
                                <div class="bg-white p-3 rounded-xl border border-slate-200">
                                    <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">Resep & Tindakan:</p>
                                    <p class="text-sm text-slate-600 font-semibold"><%= medis.obat %></p>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

        <% if (user.role === 'admin') { %>
        <div class="space-y-8">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2 space-y-8">
                    
                    <div class="bg-slate-900 p-8 rounded-[2.5rem] shadow-2xl shadow-slate-200 border border-slate-800">
                        <h3 class="text-xl font-extrabold text-white mb-8 flex items-center">
                            <i class="fas fa-chart-pie mr-3 text-emerald-400"></i> Visualisasi Kunjungan Poli
                        </h3>
                        <div class="h-64">
                            <canvas id="poliChart"></canvas>
                        </div>
                    </div>

                    <div class="bg-white p-8 rounded-[2.5rem] card-shadow border border-slate-100">
                        <h3 class="text-2xl font-black text-slate-800 mb-6">Manajemen Pasien Hari Ini</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead>
                                    <tr class="text-slate-400 font-bold uppercase text-[10px] border-b border-slate-100">
                                        <th class="pb-4">Nama Pasien</th><th class="pb-4">Layanan Poli</th><th class="pb-4 text-center">Kode Booking</th><th class="pb-4 text-right">Aksi Kontrol</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-50">
                                    <% bookings.forEach(book => { %>
                                    <tr class="hover:bg-indigo-50/30 transition-colors">
                                        <td class="py-5 font-extrabold text-slate-800"><%= book.nama_pasien %></td>
                                        <td class="py-5">
                                            <span class="px-3 py-1 bg-slate-100 rounded-full text-[10px] font-bold text-slate-600 uppercase"><%= book.layanan %></span>
                                        </td>
                                        <td class="py-5 text-center font-mono text-xs font-bold text-indigo-600"><%= book.kode_booking %></td>
                                        <td class="py-5 text-right">
                                            <form action="/admin/update-status/<%= book.kode_booking %>" method="POST" class="inline">
                                                <input type="hidden" name="status_baru" value="<%= book.status === 'menunggu' ? 'valid' : 'selesai' %>">
                                                <button class="px-4 py-2 <%= book.status === 'menunggu' ? 'bg-indigo-600' : 'bg-emerald-500' %> text-white rounded-xl font-bold uppercase text-[9px] hover:scale-105 transition-all shadow-lg">
                                                    <%= book.status === 'menunggu' ? 'Konfirmasi' : 'Selesaikan' %>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="bg-white p-8 rounded-[2.5rem] card-shadow border border-slate-100">
                        <h3 class="text-xl font-extrabold text-slate-800 mb-6 flex items-center">
                            <i class="fas fa-cloud-upload-alt mr-3 text-sky-500"></i> Monitoring Kesehatan Lingkungan
                        </h3>
                        <form action="/report" method="POST" enctype="multipart/form-data" class="mb-8 p-6 bg-slate-50 rounded-[2rem] border-2 border-dashed border-slate-200">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
                                <input type="text" name="nama" placeholder="Judul Laporan" required class="p-4 bg-white rounded-2xl border border-slate-200 font-bold outline-none focus:ring-4 focus:ring-sky-500/10">
                                <div class="relative">
                                    <input type="file" name="photo" accept="image/*" required class="w-full text-xs text-slate-500 file:mr-4 file:py-3 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-black file:bg-sky-50 file:text-sky-700 hover:file:bg-sky-100 cursor-pointer">
                                </div>
                            </div>
                            <button type="submit" class="w-full bg-slate-900 text-sky-400 font-black py-4 rounded-2xl hover:bg-sky-600 hover:text-white transition-all shadow-xl shadow-sky-100 uppercase tracking-widest text-xs">Simpan ke Amazon S3</button>
                        </form>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <% reports.forEach(report => { %>
                            <div class="group relative rounded-2xl overflow-hidden h-36 card-shadow">
                                <img src="<%= report.foto_url %>" class="w-full h-full object-cover transition duration-500 group-hover:scale-110" onerror="this.src='https://via.placeholder.com/300?text=S3+Asset'">
                                <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent opacity-80"></div>
                                <div class="absolute bottom-0 p-3 w-full">
                                    <p class="text-[9px] text-sky-300 font-black uppercase"><%= report.nama %></p>
                                </div>
                            </div>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <div class="bg-indigo-700 p-8 rounded-[2.5rem] text-white shadow-2xl h-fit sticky top-24 border border-indigo-500 shadow-indigo-200">
                    <h3 class="text-xl font-extrabold mb-8 flex items-center">
                        <i class="fas fa-pen-nib mr-3"></i> Form Rekam Medis
                    </h3>
                    <form action="/admin/rekam-medis" method="POST" class="space-y-6">
                        <div class="space-y-1">
                            <label class="text-[10px] font-black text-indigo-200 uppercase ml-2 tracking-widest">Pilih Pasien</label>
                            <select name="pasien_id" class="w-full p-4 bg-indigo-800/50 border border-indigo-400/50 rounded-2xl text-white font-bold outline-none focus:ring-4 focus:ring-white/10">
                                <% pasiens.forEach(p => { %><option value="<%= p.id %>"><%= p.nama_lengkap %> (ID: <%= p.id %>)</option><% }) %>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-black text-indigo-200 uppercase ml-2 tracking-widest">Diagnosis Medis</label>
                            <textarea name="diagnosis" placeholder="Tulis hasil pemeriksaan..." rows="4" class="w-full p-4 bg-indigo-800/50 border border-indigo-400/50 rounded-2xl text-white font-medium outline-none placeholder:text-indigo-300/50"></textarea>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-black text-indigo-200 uppercase ml-2 tracking-widest">Resep / Obat</label>
                            <input type="text" name="obat" placeholder="Daftar obat..." class="w-full p-4 bg-indigo-800/50 border border-indigo-400/50 rounded-2xl text-white font-bold outline-none placeholder:text-indigo-300/50">
                        </div>
                        <button class="w-full bg-white text-indigo-700 font-black py-5 rounded-2xl hover:bg-emerald-400 hover:text-slate-900 transition-all shadow-2xl uppercase tracking-widest text-xs">Arsip Rekam Medis</button>
                    </form>
                    <a href="/admin/history-medis" class="block text-center mt-8 text-[9px] text-indigo-100 hover:text-emerald-400 uppercase font-black tracking-[0.3em] transition-all">Cetak Laporan Arsip</a>
                </div>
            </div>
        </div>

        <script>
            const ctx = document.getElementById('poliChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['<%= stats.map(s => s.layanan).join("','") %>'],
                    datasets: [{
                        label: 'Pasien Terdaftar',
                        data: [<%= stats.map(s => s.jumlah).join(",") %>],
                        backgroundColor: [
                            '#10b981', // Emerald
                            '#6366f1', // Indigo
                            '#0ea5e9'  // Sky
                        ],
                        borderRadius: 15,
                        barThickness: 45,
                        hoverBackgroundColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { 
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#0f172a',
                            titleFont: { size: 12, weight: 'bold' },
                            bodyFont: { size: 12 },
                            padding: 12,
                            displayColors: false
                        }
                    },
                    scales: { 
                        y: { 
                            beginAtZero: true, 
                            grid: { color: '#334155', borderDash: [5, 5] }, 
                            ticks: { color: '#94a3b8', font: { weight: 'bold' } } 
                        }, 
                        x: { 
                            grid: { display: false }, 
                            ticks: { color: '#ffffff', font: { weight: 'bold', size: 10 } } 
                        } 
                    }
                }
            });
        </script>
        <% } %>
    </div>

    <script>
        const dateInput = document.getElementById('inputTgl');
        if(dateInput) {
            const today = new Date().toISOString().split("T")[0];
            dateInput.min = today;
        }
    </script>
</body>
</html>