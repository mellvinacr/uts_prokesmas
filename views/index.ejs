<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProKesMas - Smart Health Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
</head>

<body class="bg-slate-50 font-sans leading-normal tracking-normal">

    <nav class="bg-blue-700 p-4 shadow-md text-white">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold"><i class="fas fa-hospital-user mr-2"></i>ProKesMas</h1>
            <div class="space-x-4">
                <span class="bg-blue-800 px-3 py-1 rounded-full text-sm">Role: <span
                        id="currentRole">Pasien</span></span>
                <button onclick="toggleRole()"
                    class="text-xs bg-white text-blue-700 px-2 py-1 rounded hover:bg-slate-200">Switch Role
                    (Simulasi)</button>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-6">
        <div id="sectionPasien" class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-700 mb-4 border-b pb-2"><i
                        class="fas fa-calendar-check text-blue-600 mr-2"></i>Booking Layanan H+1</h3>
                <form action="/booking" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-600">Nama Lengkap</label>
                        <input type="text" name="nama_pasien" required
                            class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-600">Pilih Poli</label>
                        <select name="layanan"
                            class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
                            <option>Poli Umum</option>
                            <option>Poli Gigi</option>
                            <option>Poli KIA/Imunisasi</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-600">Tanggal Kunjungan (H+1 Min)</label>
                        <input type="date" id="inputTgl" name="tanggal" required
                            class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
                    </div>
                    <button type="submit"
                        class="w-full bg-blue-600 text-white font-bold py-2 rounded-lg hover:bg-blue-700 transition">Buat
                        Janji & Dapatkan Tiket</button>
                </form>

                <% if (typeof newBookingCode !=='undefined' ) { %>
                    <div class="mt-6 p-4 border-2 border-dashed border-slate-300 rounded-lg text-center bg-slate-50">
                        <p class="text-xs font-bold text-slate-500 mb-2 underline">TIKET DIGITAL ANDA</p>
                        <svg id="barcodeImg" class="mx-auto"></svg>
                        <p class="mt-2 text-sm font-mono font-bold text-blue-600">
                            <%= newBookingCode %>
                        </p>
                        <script>JsBarcode("#barcodeImg", "<%= newBookingCode %>", { height: 40 });</script>
                    </div>
                    <% } %>
            </div>

            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-700 mb-4 border-b pb-2"><i
                        class="fas fa-bullhorn text-green-600 mr-2"></i>Laporan Kesehatan Lingkungan</h3>
                <form action="/report" method="POST" enctype="multipart/form-data" class="space-y-4">
                    <input type="text" name="nama" placeholder="Nama Pelapor" required
                        class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none">
                    <textarea name="deskripsi" placeholder="Deskripsi Masalah (cth: Genangan Air)" rows="3" required
                        class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none"></textarea>
                    <div class="border-2 border-dashed p-4 rounded-lg text-center">
                        <label class="cursor-pointer text-slate-500 text-sm">
                            <i class="fas fa-cloud-upload-alt text-2xl mb-2 block"></i>
                            <span>Klik untuk upload foto (Simpan di S3)</span>
                            <input type="file" name="photo" class="hidden" accept="image/*">
                        </label>
                    </div>
                    <button type="submit"
                        class="w-full bg-green-600 text-white font-bold py-2 rounded-lg hover:bg-green-700 transition">Kirim
                        Laporan</button>
                </form>
            </div>
        </div>

        <div id="sectionAdmin" class="hidden space-y-6">
            <div class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-orange-500">
                <h3 class="text-xl font-bold mb-4">Panel Validasi Admin</h3>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="bg-slate-100">
                                <th class="p-3">Kode</th>
                                <th class="p-3">Pasien</th>
                                <th class="p-3">Poli</th>
                                <th class="p-3">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="adminTableBody">
                            <% if (bookings && bookings.length> 0) { %>
                                <% bookings.forEach(book=> { %>
                                    <tr class="border-b">
                                        <td class="p-3 font-mono">
                                            <%= book.kode_booking %>
                                        </td>
                                        <td class="p-3">
                                            <%= book.nama_pasien %>
                                        </td>
                                        <td class="p-3">
                                            <%= book.layanan %>
                                        </td>
                                        <td class="p-3">
                                            <button onclick="checkIn('<%= book.kode_booking %>')"
                                                class="bg-orange-500 text-white px-3 py-1 rounded text-sm hover:bg-orange-600">Validasi</button>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="rekamMedisForm" class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-700 mb-4 border-b pb-2 italic text-blue-600">Form Rekam Medis
                    (Input Admin)</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input type="text" placeholder="Diagnosis Pasien" class="p-2 border rounded-lg">
                    <input type="text" placeholder="Obat / Tindakan" class="p-2 border rounded-lg">
                    <button class="bg-blue-600 text-white px-4 py-2 rounded-lg md:col-span-2">Simpan Rekam Medis &
                        Selesai</button>
                </div>
            </div>
        </div>

        <div class="mt-12">
            <h3 class="text-2xl font-bold text-slate-800 mb-6 flex items-center">
                <span class="w-2 h-8 bg-blue-600 mr-3"></span>
                Monitoring Laporan Lingkungan (Live S3)
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <% if (reports && reports.length> 0) { %>
                    <% reports.forEach(report=> { %>
                        <div class="bg-white rounded-xl overflow-hidden shadow hover:shadow-lg transition duration-300">
                            <img src="<%= report.foto_url %>" class="w-full h-48 object-cover">
                            <div class="p-4">
                                <div class="flex justify-between items-center mb-2">
                                    <span
                                        class="text-xs font-bold px-2 py-1 bg-blue-100 text-blue-700 rounded capitalize">
                                        <%= report.nama %>
                                    </span>
                                    <span class="text-[10px] text-slate-400">
                                        <%= new Date(report.created_at).toLocaleDateString() %>
                                    </span>
                                </div>
                                <p class="text-slate-600 text-sm italic">"<%= report.deskripsi %>"</p>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="col-span-3 py-10 text-center bg-slate-200 rounded-lg text-slate-500 italic">
                                    Belum ada laporan terekam...</div>
                                <% } %>
            </div>
        </div>
    </div>

    <script>
        // Logika Batasi Tanggal Minimal Besok (H+1)
        const dateInput = document.getElementById('inputTgl');
        const tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1);
        dateInput.min = tomorrow.toISOString().split("T")[0];

        // Simulasi Role Switch untuk UTS
        function toggleRole() {
            const current = document.getElementById('currentRole');
            const secPasien = document.getElementById('sectionPasien');
            const secAdmin = document.getElementById('sectionAdmin');

            if (current.innerText === "Pasien") {
                current.innerText = "Admin";
                secPasien.classList.add('hidden');
                secAdmin.classList.remove('hidden');
            } else {
                current.innerText = "Pasien";
                secPasien.classList.remove('hidden');
                secAdmin.classList.add('hidden');
            }
        }

        function checkIn(kode) {
            alert("Booking " + kode + " Berhasil divalidasi. Pasien dipersilakan masuk.");
        }
    </script>
</body>

</html>