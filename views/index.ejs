<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProKesMas - E-Health Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <style>
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); }
        .bg-medical { background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); }
    </style>
</head>
<body class="bg-medical min-h-screen font-sans">

    <nav class="glass sticky top-0 z-50 border-b border-emerald-100 p-4 shadow-sm">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <div class="bg-emerald-600 p-2 rounded-lg text-white">
                    <i class="fas fa-hand-holding-medical text-xl"></i>
                </div>
                <h1 class="text-2xl font-black text-emerald-900 tracking-tighter">ProKesMas</h1>
            </div>
            <div class="flex items-center space-x-4">
                <div class="text-right hidden md:block">
                    <p class="text-xs font-bold text-emerald-600 uppercase tracking-widest">Active Role</p>
                    <p class="text-sm font-black text-slate-800" id="currentRoleDisplay"><%= user.role %></p>
                </div>
                <a href="/logout" class="bg-red-50 text-red-600 px-4 py-2 rounded-xl font-bold text-sm hover:bg-red-600 hover:text-white transition">
                    <i class="fas fa-power-off"></i>
                </a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-6">
        
        <% if (user.role === 'pasien') { %>
        <div id="sectionPasien" class="space-y-8">
            <div class="glass p-8 rounded-[2rem] border border-white shadow-xl flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="flex items-center space-x-6">
                    <div class="relative">
                        <div class="w-24 h-24 bg-emerald-600 rounded-3xl rotate-12 flex items-center justify-center text-white text-4xl font-black shadow-lg">
                            <span class="-rotate-12"><%= myProfile.nama_lengkap.charAt(0) %></span>
                        </div>
                    </div>
                    <div>
                        <h2 class="text-3xl font-black text-slate-800"><%= myProfile.nama_lengkap %></h2>
                        <p class="text-emerald-700 font-bold"><i class="fas fa-map-marker-alt mr-2"></i><%= myProfile.alamat %></p>
                        <span class="inline-block mt-2 bg-white px-3 py-1 rounded-full text-xs font-bold text-slate-500 shadow-sm border border-emerald-50">ID Pasien: #00<%= myProfile.id %></span>
                    </div>
                </div>
                <div class="bg-white p-6 rounded-[1.5rem] shadow-inner text-center min-w-[150px] border border-emerald-50">
                    <p class="text-5xl font-black text-emerald-600"><%= getAge(myProfile.tgl_lahir) %></p>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mt-1">Tahun (Usia)</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-emerald-100">
                    <h3 class="text-xl font-black text-slate-800 mb-6 flex items-center">
                        <i class="fas fa-calendar-plus mr-3 text-emerald-500 text-2xl"></i> Booking H+1
                    </h3>
                    <form action="/booking" method="POST" class="space-y-4">
                        <input type="hidden" name="nama_pasien" value="<%= myProfile.nama_lengkap %>">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="text-xs font-bold text-slate-400 uppercase ml-2">Pilih Poli</label>
                                <select name="layanan" class="w-full mt-1 p-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-emerald-500 outline-none font-bold text-slate-700">
                                    <option>Poli Umum</option>
                                    <option>Poli Gigi</option>
                                    <option>Poli KIA/Imunisasi</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-xs font-bold text-slate-400 uppercase ml-2">Tanggal</label>
                                <input type="date" id="inputTgl" name="tanggal" required class="w-full mt-1 p-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-emerald-500 font-bold text-slate-700">
                            </div>
                        </div>
                        <button type="submit" class="w-full bg-emerald-600 text-white font-black py-4 rounded-2xl hover:bg-emerald-700 hover:shadow-lg transition-all transform hover:-translate-y-1">
                            Ambil Antrean Sekarang
                        </button>
                    </form>
                    
                    <% if (typeof newBookingCode !== 'undefined' && newBookingCode) { %>
                        <div class="mt-8 p-6 bg-emerald-900 rounded-[1.5rem] text-center text-white shadow-2xl overflow-hidden relative">
                            <div class="absolute top-0 right-0 p-4 opacity-10 text-6xl"><i class="fas fa-qrcode"></i></div>
                            <p class="text-xs font-bold tracking-[0.3em] mb-4">CONFIRMED BOOKING</p>
                            <div class="bg-white p-4 rounded-xl inline-block mb-4">
                                <svg id="barcodeImg"></svg>
                            </div>
                            <p class="text-xl font-mono font-black tracking-widest text-emerald-400"><%= newBookingCode %></p>
                            <script>JsBarcode("#barcodeImg", "<%= newBookingCode %>", { height: 50, displayValue: false, lineColor: "#064e3b" });</script>
                        </div>
                    <% } %>
                </div>

                <div class="bg-slate-800 p-8 rounded-[2rem] text-white shadow-xl">
                    <h3 class="text-xl font-black mb-6 flex items-center">
                        <i class="fas fa-file-medical-alt mr-3 text-emerald-400 text-2xl"></i> Rekam Medis Saya
                    </h3>
                    <div class="space-y-4 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
                        <div class="bg-slate-700/50 p-5 rounded-2xl border border-slate-600">
                            <div class="flex justify-between items-start mb-2">
                                <span class="text-xs font-bold text-emerald-400 uppercase">Diagnosis Terakhir</span>
                                <span class="text-[10px] text-slate-400">16 April 2026</span>
                            </div>
                            <p class="font-bold text-lg italic">"Gejala flu ringan dan kelelahan otot"</p>
                            <div class="mt-3 pt-3 border-t border-slate-600 text-sm text-slate-300">
                                <strong>Tindakan:</strong> Istirahat total 3 hari, konsumsi vitamin C.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

        <% if (user.role === 'admin') { %>
        <div id="sectionAdmin" class="space-y-8">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2 space-y-8">
                    <div class="glass p-8 rounded-[2rem] shadow-sm border border-white">
                        <h3 class="text-2xl font-black text-slate-800 mb-6 italic underline decoration-orange-500">Panel Validasi Antrean</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead>
                                    <tr class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-emerald-50">
                                        <th class="pb-4">Pasien</th>
                                        <th class="pb-4">Poli</th>
                                        <th class="pb-4 text-center">Kode</th>
                                        <th class="pb-4 text-right">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody class="text-slate-700">
                                    <% bookings.forEach(book => { %>
                                    <tr class="group hover:bg-white/50 transition">
                                        <td class="py-4 font-bold text-emerald-900"><%= book.nama_pasien %></td>
                                        <td class="py-4 text-sm font-medium"><%= book.layanan %></td>
                                        <td class="py-4 text-center font-mono font-black text-xs bg-slate-100 rounded-lg"><%= book.kode_booking %></td>
                                        <td class="py-4 text-right">
                                            <button onclick="checkIn('<%= book.kode_booking %>')" class="bg-emerald-600 text-white p-2 rounded-lg hover:bg-emerald-700 shadow-md">
                                                <i class="fas fa-check"></i> Valid
                                            </button>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-emerald-100">
                        <h3 class="text-xl font-black text-slate-800 mb-6 flex justify-between items-center">
                            <span>Laporan Lingkungan (S3)</span>
                            <button class="bg-emerald-100 text-emerald-700 px-4 py-2 rounded-xl text-xs font-black">UPDATE DATA</button>
                        </h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <% reports.forEach(report => { %>
                            <div class="group relative rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500">
                                <img src="<%= report.foto_url %>" class="w-full h-40 object-cover group-hover:scale-110 transition duration-700">
                                <div class="absolute inset-0 bg-gradient-to-t from-emerald-900 via-transparent to-transparent opacity-80 p-4 flex flex-col justify-end">
                                    <p class="text-white font-black text-sm uppercase tracking-tight"><%= report.nama %></p>
                                    <p class="text-emerald-200 text-[10px] truncate"><%= report.deskripsi %></p>
                                </div>
                            </div>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="bg-emerald-900 p-8 rounded-[2rem] text-white shadow-2xl sticky top-24">
                        <h3 class="text-xl font-black mb-6"><i class="fas fa-edit mr-3 text-emerald-400"></i> Input Rekam Medis</h3>
                        <form action="/admin/rekam-medis" method="POST" class="space-y-4">
                            <div>
                                <label class="text-[10px] font-black uppercase text-emerald-400 ml-1">Pilih Pasien</label>
                                <select name="pasien_nama" class="w-full mt-1 p-4 bg-emerald-800 border-none rounded-2xl text-white font-bold outline-none ring-1 ring-emerald-700">
                                    <% pasiens.forEach(p => { %>
                                        <option value="<%= p.nama_lengkap %>"><%= p.nama_lengkap %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <textarea name="diagnosis" placeholder="Hasil Diagnosis..." rows="4" class="w-full p-4 bg-emerald-800 border-none rounded-2xl text-white font-medium ring-1 ring-emerald-700"></textarea>
                            <input type="text" name="obat" placeholder="Resep Obat & Tindakan" class="w-full p-4 bg-emerald-800 border-none rounded-2xl text-white font-bold ring-1 ring-emerald-700">
                            <button class="w-full bg-emerald-400 text-emerald-900 font-black py-4 rounded-2xl hover:bg-white transition-all">SIMPAN DATA MEDIS</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

    </div>

    <script>
        // Set Min Date H+1
        const dateInput = document.getElementById('inputTgl');
        if(dateInput) {
            const tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);
            dateInput.min = tomorrow.toISOString().split("T")[0];
        }

        function checkIn(kode) {
            alert("Booking Pasien dengan Kode " + kode + " telah divalidasi. Mengarahkan ke antrean poli.");
        }
    </script>
</body>
</html>