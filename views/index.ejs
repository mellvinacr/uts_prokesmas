<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProKesMas - Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .glass {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
        }

        .bg-medical {
            background: #f1f5f9;
            background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
            background-size: 24px 24px;
        }

        .card-shadow {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 5px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #64748b;
            border-radius: 10px;
        }
    </style>
</head>

<body class="bg-medical min-h-screen text-slate-900">

    <nav class="bg-slate-900 sticky top-0 z-50 p-4 shadow-2xl">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="bg-emerald-500 p-2 rounded-xl text-slate-900 shadow-lg shadow-emerald-500/20">
                    <i class="fas fa-hospital-user text-xl"></i>
                </div>
                <h1 class="text-2xl font-extrabold text-white tracking-tighter">ProKesMas</h1>
            </div>
            <div class="flex items-center space-x-4">
                <div class="text-right hidden md:block">
                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em]">Role Aktif</p>
                    <p class="text-sm font-black text-emerald-400 uppercase">
                        <%= user.role %>
                    </p>
                </div>
                <a href="/logout"
                    class="bg-red-500/10 text-red-500 p-3 rounded-xl hover:bg-red-500 hover:text-white transition-all duration-300 border border-red-500/20">
                    <i class="fas fa-power-off"></i>
                </a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-6 space-y-8">

        <% if (user.role==='pasien' ) { %>
            <div class="space-y-8">
                <div
                    class="bg-white p-8 rounded-[2rem] card-shadow border border-white flex flex-col md:flex-row justify-between items-center gap-6">
                    <div class="flex items-center space-x-6">
                        <div
                            class="w-24 h-24 bg-indigo-600 rounded-[2rem] flex items-center justify-center text-white text-4xl font-extrabold shadow-xl shadow-indigo-200 rotate-3">
                            <%= myProfile ? myProfile.nama_lengkap.charAt(0) : 'U' %>
                        </div>
                        <div>
                            <h2 class="text-3xl font-extrabold text-slate-800">
                                <%= myProfile ? myProfile.nama_lengkap : 'User' %>
                            </h2>
                            <p class="text-slate-500 font-semibold italic"><i
                                    class="fas fa-map-marker-alt mr-2 text-indigo-500"></i>
                                <%= myProfile ? myProfile.alamat : '-' %>
                            </p>
                            <span
                                class="inline-block mt-3 bg-indigo-50 px-4 py-1.5 rounded-full text-[10px] font-bold text-indigo-700 uppercase tracking-wider border border-indigo-100">ID
                                Pasien: #00<%= user.id %></span>
                        </div>
                    </div>
                    <div class="bg-slate-900 p-6 rounded-3xl text-center min-w-[160px] shadow-2xl">
                        <p class="text-5xl font-black text-emerald-400">
                            <%= myProfile ? getAge(myProfile.tgl_lahir) : 0 %>
                        </p>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-2 italic">Usia Anda
                        </p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <div class="bg-white p-8 rounded-[2.5rem] card-shadow border border-slate-100">
                        <h3 class="text-xl font-extrabold text-slate-800 mb-6 flex items-center">
                            <i class="fas fa-calendar-check mr-3 text-indigo-600 text-2xl"></i> Registrasi Antrean
                        </h3>
                        <form action="/booking" method="POST" class="space-y-4 mb-8">
                            <input type="hidden" name="nama_pasien"
                                value="<%= myProfile ? myProfile.nama_lengkap : '' %>">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="space-y-1">
                                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Pilih
                                        Poli</label>
                                    <select name="layanan"
                                        class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl font-bold outline-none">
                                        <option>Poli Umum</option>
                                        <option>Poli Gigi</option>
                                        <option>Poli KIA/Imunisasi</option>
                                    </select>
                                </div>
                                <div class="space-y-1">
                                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Rencana
                                        Kunjungan</label>
                                    <input type="date" id="inputTgl" name="tanggal" required
                                        class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl font-bold outline-none">
                                </div>
                            </div>
                            <button type="submit"
                                class="w-full bg-indigo-600 text-white font-extrabold py-5 rounded-2xl hover:bg-indigo-700 transition-all shadow-xl">Ambil
                                Nomor Antrean</button>
                        </form>

                        <div class="space-y-4 max-h-[400px] overflow-y-auto pr-3 custom-scrollbar">
                            <% myBookings.forEach((ticket, index)=> {
                                const isExpired = new Date(ticket.tanggal) < new Date().setHours(0,0,0,0) &&
                                    ticket.status !=='selesai' ; %>
                                    <div
                                        class="p-6 rounded-3xl border-2 <%= isExpired ? 'bg-slate-50 border-slate-200' : 'bg-white border-indigo-50 shadow-sm' %> flex flex-col gap-4">
                                        <div class="flex justify-between items-start">
                                            <div>
                                                <p class="text-lg font-black">
                                                    <%= ticket.kode_booking %>
                                                </p>
                                                <p class="text-[10px] text-indigo-500 font-bold uppercase">
                                                    <%= ticket.layanan %>
                                                </p>
                                            </div>
                                            <span
                                                class="text-[9px] font-black px-3 py-1.5 rounded-full uppercase <%= isExpired ? 'bg-slate-200 text-slate-500' : 'bg-emerald-500 text-white shadow-lg shadow-emerald-200' %>">
                                                <%= isExpired ? 'Expired' : ticket.status %>
                                            </span>
                                        </div>
                                        <% if (!isExpired && ticket.status !=='selesai' ) { %>
                                            <div
                                                class="bg-slate-50 p-4 rounded-2xl flex justify-center border border-slate-100 shadow-inner">
                                                <svg id="barcode-<%= index %>"></svg>
                                            </div>
                                            <script>JsBarcode("#barcode-<%= index %>", "<%= ticket.kode_booking %>", { height: 40, width: 2, displayValue: false, margin: 0 });</script>
                                            <% } %>
                                    </div>
                                    <% }) %>
                        </div>
                    </div>

                    <div class="bg-white p-8 rounded-[2.5rem] card-shadow border border-slate-100 flex flex-col">
                        <h3 class="text-xl font-extrabold text-slate-800 mb-6 flex items-center">
                            <i class="fas fa-notes-medical mr-3 text-red-500 text-2xl"></i> Catatan Medis Digital
                        </h3>
                        <div class="space-y-4 overflow-y-auto pr-3 custom-scrollbar flex-1">
                            <% medicalHistory.forEach(medis=> { %>
                                <div
                                    class="p-6 bg-slate-50 rounded-3xl border border-slate-100 border-l-4 border-l-red-500">
                                    <p class="text-[10px] font-black text-slate-400 mb-2 uppercase">
                                        <%= new Date(medis.tanggal_periksa).toLocaleDateString() %>
                                    </p>
                                    <p class="font-extrabold text-lg text-slate-800 mb-2 italic">"<%= medis.diagnosis %>
                                            "</p>
                                    <p class="text-sm text-slate-600 font-semibold bg-white p-2 rounded-lg">Resep: <%=
                                            medis.obat %>
                                    </p>
                                </div>
                                <% }) %>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>

                <% if (user.role==='admin' ) { %>
                    <div class="space-y-8">
                        <div class="bg-slate-900 p-8 rounded-[2.5rem] shadow-2xl border border-slate-800">
                            <h3 class="text-xl font-extrabold text-white mb-8 flex items-center">
                                <i class="fas fa-chart-pie mr-3 text-emerald-400"></i> Visualisasi Kunjungan Poli
                            </h3>
                            <div class="h-64">
                                <canvas id="poliChart"></canvas>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                            <div class="bg-white p-8 rounded-[2.5rem] card-shadow border border-slate-100">
                                <h3 class="text-xl font-extrabold text-slate-800 mb-6">Manajemen Pasien Hari Ini</h3>
                                <div class="overflow-x-auto">
                                    <table class="w-full text-left">
                                        <thead class="text-[10px] font-bold text-slate-400 uppercase border-b">
                                            <tr>
                                                <th class="pb-4">Pasien</th>
                                                <th class="pb-4">Poli</th>
                                                <th class="pb-4 text-center">Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y text-sm">
                                            <% bookings.forEach(book=> { %>
                                                <tr class="hover:bg-slate-50">
                                                    <td class="py-4 font-extrabold">
                                                        <%= book.nama_pasien %>
                                                    </td>
                                                    <td class="py-4 text-slate-500">
                                                        <%= book.layanan %>
                                                    </td>
                                                    <td class="py-4 text-right">
                                                        <form action="/admin/update-status/<%= book.kode_booking %>"
                                                            method="POST">
                                                            <input type="hidden" name="status_baru"
                                                                value="<%= book.status === 'menunggu' ? 'valid' : 'selesai' %>">
                                                            <button
                                                                class="px-4 py-2 <%= book.status === 'menunggu' ? 'bg-indigo-600' : 'bg-emerald-500' %> text-white rounded-xl text-[10px] font-black uppercase shadow-md">
                                                                <%= book.status==='menunggu' ? 'Validasi' : 'Selesai' %>
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="bg-white p-8 rounded-[2.5rem] card-shadow border border-slate-100">
                                <div class="flex justify-between items-center mb-6">
                                    <h3 class="text-xl font-extrabold text-slate-800 flex items-center">
                                        <i class="fas fa-cloud-upload-alt mr-3 text-sky-500 text-2xl"></i> Monitoring
                                        Asset AWS S3
                                    </h3>
                                    <span
                                        class="bg-sky-50 text-sky-600 text-[10px] font-black px-3 py-1 rounded-full border border-sky-100 uppercase tracking-tighter">Connected
                                        to S3</span>
                                </div>

                                <form action="/report" method="POST" enctype="multipart/form-data"
                                    class="mb-10 p-8 bg-slate-50 rounded-[2rem] border-2 border-dashed border-slate-200 hover:border-sky-400 transition-all group">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                                        <div class="space-y-2">
                                            <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Judul
                                                Dokumentasi</label>
                                            <input type="text" name="nama" placeholder="Contoh: Kondisi Sanitasi Blok A"
                                                required
                                                class="w-full p-4 bg-white rounded-2xl border border-slate-200 font-bold outline-none focus:ring-4 focus:ring-sky-500/10">
                                        </div>
                                        <div class="space-y-2">
                                            <label class="text-[10px] font-black text-slate-400 uppercase ml-2">Pilih
                                                File Gambar</label>
                                            <input type="file" name="photo" accept="image/*" required
                                                class="w-full text-xs text-slate-500 file:mr-4 file:py-3 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-black file:bg-sky-100 file:text-sky-700 hover:file:bg-sky-200 cursor-pointer">
                                        </div>
                                    </div>
                                    <button type="submit"
                                        class="w-full bg-slate-900 text-sky-400 font-black py-5 rounded-2xl hover:bg-sky-600 hover:text-white transition-all shadow-xl uppercase tracking-[0.2em] text-xs">Sync
                                        to Amazon S3 Bucket</button>
                                </form>

                                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                                    <% reports.forEach(report=> { %>
                                        <a href="<%= report.foto_url %>" target="_blank"
                                            class="group relative rounded-[2rem] overflow-hidden h-52 shadow-lg bg-slate-50 cursor-zoom-in block">

                                            <img src="<%= report.foto_url %>" class="w-full h-full object-cover"
                                                onerror="this.src='https://via.placeholder.com/500?text=S3+Asset+Pending'">

                                            <div
                                                class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent">
                                            </div>
                                            <div class="absolute bottom-0 p-5 w-full">
                                                <p class="text-[10px] text-sky-400 font-bold uppercase mb-1">Klik untuk
                                                    Memperbesar</p>
                                                <h4 class="text-white font-bold text-sm truncate">
                                                    <%= report.nama %>
                                                </h4>
                                            </div>
                                        </a>
                                        <% }) %>
                                </div>
                            </div>
                        </div>

                        <div class="bg-indigo-700 p-8 rounded-[2.5rem] text-white shadow-2xl">
                            <h3 class="text-xl font-extrabold mb-8 flex items-center"><i
                                    class="fas fa-pen-nib mr-3"></i> Input Rekam Medis Digital</h3>
                            <form action="/admin/rekam-medis" method="POST"
                                class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                <div class="space-y-1">
                                    <label class="text-[10px] font-black text-indigo-200 uppercase">Pilih Pasien</label>
                                    <select name="pasien_id"
                                        class="w-full p-4 bg-indigo-800/50 border border-indigo-400/50 rounded-2xl text-white font-bold outline-none">
                                        <% pasiens.forEach(p=> { %><option value="<%= p.id %>">
                                                <%= p.nama_lengkap %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>
                                <div class="space-y-1">
                                    <label class="text-[10px] font-black text-indigo-200 uppercase">Diagnosis</label>
                                    <input type="text" name="diagnosis" placeholder="Hasil pemeriksaan..."
                                        class="w-full p-4 bg-indigo-800/50 border border-indigo-400/50 rounded-2xl text-white outline-none">
                                </div>
                                <div class="space-y-1">
                                    <label class="text-[10px] font-black text-indigo-200 uppercase">Resep Obat</label>
                                    <input type="text" name="obat" placeholder="Daftar obat..."
                                        class="w-full p-4 bg-indigo-800/50 border border-indigo-400/50 rounded-2xl text-white outline-none">
                                </div>
                                <button
                                    class="md:col-span-3 bg-white text-indigo-700 font-black py-4 rounded-2xl hover:bg-emerald-400 transition-all uppercase tracking-widest text-xs">Arsip
                                    Rekam Medis</button>
                            </form>
                        </div>
                    </div>

                    <script>
                        const ctx = document.getElementById('poliChart').getContext('2d');
                        new Chart(ctx, {
                            type: 'bar',
                            data: {
                                // INI PERBAIKANNYA: Pakai map untuk membuat array string murni
                                labels: [<% stats.forEach(function (s, i) { %> '<%= s.layanan %>' <%= i < stats.length - 1 ? ',' : '' %> <% }) %>],
                                datasets: [{
                                    label: 'Jumlah Pasien',
                                    data: [<%= stats.map(s => s.jumlah).join(",") %>],
                                    backgroundColor: [
                                        '#10b981', // Emerald (Umum)
                                        '#6366f1', // Indigo (Gigi)
                                        '#f43f5e', // Rose (KIA)
                                        '#0ea5e9'  // Sky (Lainnya)
                                    ],
                                    borderRadius: 12,
                                    barThickness: 50
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { display: false },
                                    tooltip: { backgroundColor: '#0f172a' }
                                },
                                scales: {
                                    y: {
                                        beginAtZero: true,
                                        grid: { color: '#e2e8f0', borderDash: [5, 5] },
                                        ticks: { stepSize: 1, font: { weight: 'bold' } }
                                    },
                                    x: {
                                        grid: { display: false },
                                        ticks: { font: { weight: 'bold' }, color: '#475569' }
                                    }
                                }
                            }
                        });
                    </script>
                    <% } %>
    </div>
</body>

</html>