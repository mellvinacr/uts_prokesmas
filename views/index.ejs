<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProKesMas - Portal Kesehatan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .header { background: #0d6efd; color: white; padding: 2rem 0; margin-bottom: 2rem; }
    </style>
</head>
<body>
    <div class="header text-center">
        <h1>🏥 ProKesMas</h1>
        <p>Program Kesehatan Masyarakat Berbasis Cloud</p>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">📝 Laporan Kesehatan Lingkungan</div>
                    <div class="card-body">
                        <form action="/report" method="POST" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="form-label">Nama Pelapor</label>
                                <input type="text" name="nama" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Deskripsi Masalah</label>
                                <textarea name="deskripsi" class="form-control" rows="3" required></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Foto Bukti (Upload ke S3)</label>
                                <input type="file" name="photo" class="form-control" accept="image/*" required>
                            </div>
                            <button type="submit" class="btn btn-success w-100">Kirim Laporan</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">🗓️ Booking Layanan Puskesmas</div>
                    <div class="card-body">
                        <form action="/booking" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Nama Pasien</label>
                                <input type="text" name="nama_pasien" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Layanan</label>
                                <select name="layanan" class="form-select">
                                    <option value="Poli Umum">Poli Umum</option>
                                    <option value="Poli Gigi">Poli Gigi</option>
                                    <option value="KIA/Imunisasi">KIA/Imunisasi</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Tanggal Kunjungan</label>
                                <input type="date" name="tanggal" class="form-control" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Buat Janji</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <hr>

        <h3 class="mb-4">📊 Dasbor Pemantauan Lingkungan</h3>
        <div class="row">
            <% if (reports && reports.length > 0) { %>
                <% reports.forEach(report => { %>
                    <div class="col-md-4 mb-3">
                        <div class="card shadow-sm">
                            <img src="<%= report.foto_url %>" class="card-img-top" alt="Bukti" style="height: 200px; object-fit: cover;">
                            <div class="card-body">
                                <h5 class="card-title"><%= report.nama %></h5>
                                <p class="card-text"><%= report.deskripsi %></p>
                                <small class="text-muted"><%= new Date(report.created_at).toLocaleString() %></small>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="alert alert-info w-100 text-center">Belum ada laporan yang masuk.</div>
            <% } %>
        </div>
    </div>
</body>
</html>