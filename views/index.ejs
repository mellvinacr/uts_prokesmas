<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProKesMas - Premium Health Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <style>
        .glass { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); }
        .bg-medical { background: #f8fafc; background-image: radial-gradient(#e2e8f0 1px, transparent 1px); background-size: 20px 20px; }
    </style>
</head>
<body class="bg-medical min-h-screen font-sans text-slate-900">

    <nav class="glass sticky top-0 z-50 border-b border-slate-200 p-4 shadow-sm">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <div class="bg-emerald-600 p-2 rounded-xl text-white shadow-lg">
                    <i class="fas fa-hospital-user text-xl"></i>
                </div>
                <h1 class="text-2xl font-black text-slate-800 tracking-tighter">ProKesMas</h1>
            </div>
            <div class="flex items-center space-x-4 text-sm font-black">
                <p class="text-emerald-700 uppercase tracking-widest"><%= user.role %></p>
                <a href="/logout" class="bg-slate-100 p-2 rounded-lg hover:bg-red-500 hover:text-white transition"><i class="fas fa-power-off"></i></a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto p-6">
        
        <% if (user.role === 'pasien') { %>
        <div class="space-y-8">
            <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100 flex justify-between items-center">
                <div class="flex items-center space-x-6">
                    <div class="w-20 h-20 bg-slate-900 rounded-2xl flex items-center justify-center text-emerald-400 text-3xl font-black rotate-3">
                        <%= myProfile ? myProfile.nama_lengkap.charAt(0) : 'U' %>
                    </div>
                    <div>
                        <h2 class="text-2xl font-black text-slate-800"><%= myProfile ? myProfile.nama_lengkap : 'User' %></h2>
                        <p class="text-slate-400 text-xs font-bold uppercase tracking-widest"><%= myProfile ? myProfile.alamat : '-' %></p>
                    </div>
                </div>
                <div class="text-center">
                    <p class="text-4xl font-black text-slate-800"><%= myProfile ? getAge(myProfile.tgl_lahir) : 0 %></p>
                    <p class="text-[10px] font-bold text-slate-400 uppercase">Tahun</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100">
                    <h3 class="text-lg font-black mb-6 flex items-center"><i class="fas fa-calendar-alt mr-3 text-emerald-500"></i> Ambil Antrean</h3>
                    <form action="/booking" method="POST" class="space-y-4">
                        <input type="hidden" name="nama_pasien" value="<%= myProfile ? myProfile.nama_lengkap : '' %>">
                        <select name="layanan" class="w-full p-4 bg-slate-50 border-none rounded-2xl font-bold outline-none ring-1 ring-slate-200">
                            <option>Poli Umum</option><option>Poli Gigi</option><option>Poli KIA/Imunisasi</option>
                        </select>
                        <input type="date" id="inputTgl" name="tanggal" required class="w-full p-4 bg-slate-50 border-none rounded-2xl font-bold ring-1 ring-slate-200">
                        <button type="submit" class="w-full bg-slate-900 text-emerald-400 font-black py-4 rounded-2xl hover:bg-emerald-600 hover:text-white transition">DAPATKAN TIKET</button>
                    </form>

                    <% if (newBookingCode) { %>
                        <div class="mt-8 p-6 bg-slate-50 rounded-3xl text-center border-2 border-dashed border-slate-200">
                            <svg id="barcodeImg" class="mx-auto mb-2"></svg>
                            <p class="text-xs font-mono font-black text-slate-800"><%= newBookingCode %></p>
                            <script>JsBarcode("#barcodeImg", "<%= newBookingCode %>", { height: 40, width: 2, displayValue: false });</script>
                        </div>
                    <% } %>

                    <div class="mt-8 space-y-3">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Riwayat Antrean Anda</p>
                        <% myBookings.forEach(ticket => { 
                            const isExpired = new Date(ticket.tanggal) < new Date().setHours(0,0,0,0) && ticket.status !== 'selesai';
                        %>
                        <div class="flex justify-between items-center p-3 rounded-xl border <%= isExpired ? 'bg-red-50 border-red-100 opacity-60' : 'bg-white border-slate-100' %>">
                            <div class="text-[10px] font-bold">
                                <p class="<%= isExpired ? 'line-through' : '' %>"><%= ticket.kode_booking %> (<%= ticket.layanan %>)</p>
                                <p class="text-slate-400"><%= new Date(ticket.tanggal).toLocaleDateString() %></p>
                            </div>
                            <span class="text-[8px] font-black px-2 py-1 rounded <%= isExpired ? 'bg-red-200 text-red-700' : 'bg-emerald-100 text-emerald-700' %> uppercase">
                                <%= isExpired ? 'Expired' : ticket.status %>
                            </span>
                        </div>
                        <% }) %>
                    </div>
                </div>

                <div class="bg-slate-900 p-8 rounded-[2.5rem] text-white shadow-2xl overflow-y-auto max-h-[600px]">
                    <h3 class="text-lg font-black mb-6 text-emerald-400 flex items-center"><i class="fas fa-history mr-3"></i> Rekam Medis</h3>
                    <% if (medicalHistory.length > 0) { %>
                        <% medicalHistory.forEach(medis => { %>
                            <div class="mb-4 p-4 bg-slate-800 rounded-2xl border border-slate-700">
                                <p class="text-[9px] font-bold text-slate-500 mb-1"><%= new Date(medis.tanggal_periksa).toLocaleDateString() %></p>
                                <p class="font-bold text-emerald-50 italic">"<%= medis.diagnosis %>"</p>
                                <p class="text-xs text-slate-400 mt-2">Tindakan: <%= medis.obat %></p>
                            </div>
                        <% }) %>
                    <% } else { %><p class="text-slate-600 text-center py-10">Kosong.</p><% } %>
                </div>
            </div>
        </div>
        <% } %>

        <% if (user.role === 'admin') { %>
        <div class="space-y-8">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2 space-y-8">
                    <div class="bg-white p-8 rounded-[2.5rem] shadow-sm">
                        <h3 class="text-xl font-black mb-6">Validasi Antrean</h3>
                        <table class="w-full text-left text-xs">
                            <tbody class="divide-y divide-slate-50">
                                <% bookings.forEach(book => { %>
                                <tr class="hover:bg-slate-50 transition">
                                    <td class="py-4 font-bold"><%= book.nama_pasien %></td>
                                    <td class="py-4 font-mono text-emerald-600"><%= book.kode_booking %></td>
                                    <td class="py-4 text-right">
                                        <form action="/admin/update-status/<%= book.kode_booking %>" method="POST" class="inline">
                                            <input type="hidden" name="status_baru" value="<%= book.status === 'menunggu' ? 'valid' : 'selesai' %>">
                                            <button class="bg-slate-900 text-white px-3 py-1 rounded-lg font-black uppercase text-[8px]"><%= book.status === 'menunggu' ? 'Validasi' : 'Panggil' %></button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="bg-white p-8 rounded-[2.5rem] shadow-sm">
                        <h3 class="text-xl font-black mb-6">Laporan Lingkungan</h3>
                        <form action="/report" method="POST" enctype="multipart/form-data" class="mb-6 p-4 bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200">
                            <input type="text" name="nama" placeholder="Judul" class="w-full p-2 mb-2 rounded-lg border-none ring-1 ring-slate-200 font-bold">
                            <input type="file" name="photo" class="text-[10px] mb-2 block">
                            <button type="submit" class="w-full bg-slate-900 text-emerald-400 font-black py-2 rounded-xl">UPLOAD S3</button>
                        </form>
                        <div class="grid grid-cols-3 gap-3">
                            <% reports.forEach(report => { %>
                            <div class="rounded-xl overflow-hidden h-24 border border-slate-100 shadow-sm">
                                <img src="<%= report.foto_url %>" class="w-full h-full object-cover">
                            </div>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-900 p-8 rounded-[2.5rem] text-white shadow-2xl h-fit sticky top-24">
                    <h3 class="text-lg font-black mb-6 text-emerald-400">Rekam Medis</h3>
                    <form action="/admin/rekam-medis" method="POST" class="space-y-4">
                        <select name="pasien_id" class="w-full p-3 bg-slate-800 rounded-xl font-bold ring-1 ring-slate-700 outline-none">
                            <% pasiens.forEach(p => { %><option value="<%= p.id %>"><%= p.nama_lengkap %></option><% }) %>
                        </select>
                        <textarea name="diagnosis" placeholder="Diagnosis..." class="w-full p-3 bg-slate-800 rounded-xl outline-none"></textarea>
                        <input type="text" name="obat" placeholder="Resep" class="w-full p-3 bg-slate-800 rounded-xl outline-none font-bold">
                        <button class="w-full bg-emerald-500 text-slate-900 font-black py-4 rounded-xl shadow-lg">SIMPAN & ARSIP</button>
                    </form>
                    <a href="/admin/history-medis" class="block text-center mt-4 text-[10px] text-slate-500 hover:text-white uppercase font-black">Lihat Semua Arsip</a>
                </div>
            </div>
        </div>
        <% } %>
    </div>
</body>
</html>