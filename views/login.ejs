<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>ProKesMas - Login</title>
</head>
<body class="bg-emerald-900 flex items-center justify-center h-screen p-6">
    <div class="bg-white w-full max-w-md p-10 rounded-[2.5rem] shadow-2xl">
        <div class="text-center mb-10">
            <h1 class="text-4xl font-black text-emerald-900 tracking-tighter">ProKesMas</h1>
            <p class="text-slate-400 font-bold text-sm uppercase mt-2">Health Cloud Portal</p>
        </div>

        <form action="/login" method="POST" class="space-y-6">
            <div>
                <label class="text-xs font-black text-slate-400 uppercase ml-1">Username</label>
                <input type="text" name="username" required class="w-full p-4 bg-slate-100 border-none rounded-2xl focus:ring-2 focus:ring-emerald-500 outline-none font-bold text-slate-700">
            </div>
            <div>
                <label class="text-xs font-black text-slate-400 uppercase ml-1">Password</label>
                <input type="password" name="password" required class="w-full p-4 bg-slate-100 border-none rounded-2xl focus:ring-2 focus:ring-emerald-500 outline-none font-bold text-slate-700">
            </div>
            <button type="submit" class="w-full bg-emerald-600 text-white font-black py-4 rounded-2xl hover:bg-emerald-700 transition-all shadow-lg">MASUK SISTEM</button>
        </form>

        <div class="mt-10 border-t pt-6 text-center">
            <p class="text-slate-400 text-xs">Belum punya akun? <a href="/register-page" class="text-emerald-600 font-black">Daftar Pasien</a></p>
        </div>
    </div>
</body>
</html>